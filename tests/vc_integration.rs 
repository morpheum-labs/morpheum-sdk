/// Test self-revocation flow.
#[tokio::test]
async fn test_self_revoke_vc() {
    let sdk = test_sdk();
    let signer = test_native_signer();

    let revoke_request = VcSelfRevokeBuilder::new()
        .vc_id("vc_test_001")
        .subject(signer.account_id())
        .agent_signature(vec![0u8; 64])
        .reason("Integration test self-revocation")
        .build()
        .expect("Self-revoke builder should succeed");

    let signed_tx = TxBuilder::new(signer)
        .chain_id(TEST_CHAIN_ID)
        .memo("Self-revoking VC via SDK integration test")
        .add_message(revoke_request.to_any())
        .sign()
        .await
        .expect("Signing self-revoke should succeed");

    assert!(!signed_tx.txhash_hex().is_empty());
}

/// Test claim verification failure case.
#[tokio::test]
async fn test_claim_verification_failure() {
    let now_secs = std::time::SystemTime::now()
        .duration_since(std::time::UNIX_EPOCH)
        .unwrap()
        .as_secs();

    let claim = test_trading_key_claim(
        AccountId::new([0x11; 32]),
        AccountId::new([0x22; 32]),
        now_secs,
    )
    .unwrap();

    // Wrong issuer should fail verification
    let result = claim.verify(now_secs, &AccountId::new([0xFF; 32]));
    assert!(result.is_err(), "Verification with wrong issuer should fail");
}

/// End-to-end sanity test for the entire VC module.
#[tokio::test]
async fn test_vc_module_end_to_end_sanity() {
    println!("Running VC module end-to-end sanity checks...");

    test_issue_vc_with_trading_key_claim().await;
    test_query_vc().await;
    test_query_vc_status().await;
    test_self_revoke_vc().await;
    test_claim_verification_failure().await;

    println!("✅ All VC module integration tests passed!");
}