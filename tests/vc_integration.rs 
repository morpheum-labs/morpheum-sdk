//! Integration tests for the VC (Verifiable Credentials) module.
//!
//! These tests verify the full end-to-end flow for VC operations using the
//! Morpheum SDK, including claim building, verification, issuance, revocation,
//! and queries. All tests use deterministic test data from `common.rs`.

use super::common::*;
use morpheum_sdk_native::prelude::*;
use morpheum_sdk_vc::prelude::*;
use std::error::Error;

/// Test issuing a VC with a verified TradingKeyClaim (core agent delegation flow).
#[tokio::test]
async fn test_issue_vc_with_trading_key_claim() {
    let sdk = test_sdk();
    let now_secs = std::time::SystemTime::now()
        .duration_since(std::time::UNIX_EPOCH)
        .unwrap()
        .as_secs();

    // Create owner and agent signers
    let owner_signer = test_native_signer();
    let agent_signer = test_agent_signer();

    // Build and verify a TradingKeyClaim
    let claim = test_trading_key_claim(
        owner_signer.account_id(),
        agent_signer.account_id(),
        now_secs,
    )
    .expect("Test TradingKeyClaim should be valid");

    claim.verify(now_secs, &owner_signer.account_id())
        .expect("Claim verification should succeed");

    println!("✅ TradingKeyClaim built and verified");

    // Build VC issuance request
    let claims = VcClaims {
        max_daily_usd: 500_000,
        allowed_pairs_bitflags: 0b0001, // BTC/USDC
        max_slippage_bps: 50,
        max_position_usd: 1_000_000,
        custom_constraints: Some("{\"max_leverage\": 20}".into()),
    };

    let issue_request = VcIssueBuilder::new()
        .issuer(owner_signer.account_id())
        .subject(agent_signer.account_id())
        .claims(claims)
        .expiry(now_secs + 86_400)
        .issuer_signature(vec![0u8; 64]) // Placeholder signature
        .build()
        .expect("VcIssueBuilder should succeed");

    // Sign the transaction with the agent's TradingKey
    let signed_tx = TxBuilder::new(agent_signer)
        .chain_id(TEST_CHAIN_ID)
        .memo("Agent issuing VC with verified TradingKeyClaim")
        .with_trading_key_claim(claim)
        .add_message(issue_request.to_any())
        .sign()
        .await
        .expect("Signing VC issuance should succeed");

    assert!(!signed_tx.txhash_hex().is_empty());
    assert!(!signed_tx.raw_bytes().is_empty());

    println!("✅ VC issuance test passed. TxHash: {}", signed_tx.txhash_hex());
}

